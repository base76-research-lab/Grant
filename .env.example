# Grant authentication mode
# api_key (default) or oauth
GRANT_AUTH_MODE=api_key

# single_user (default) or multi_tenant
GRANT_TENANT_MODE=single_user
GRANT_USER_ID=local_user

# OAuth settings (required only when GRANT_AUTH_MODE=oauth)
GRANT_OAUTH_PROVIDER=
GRANT_OAUTH_CLIENT_ID=
GRANT_OAUTH_REDIRECT_URI=

# Source API keys (optional for current public endpoints, ready for protected variants)
VINNOVA_API_KEY=
GRANTS_GOV_API_KEY=
EU_SEDIA_API_KEY=
